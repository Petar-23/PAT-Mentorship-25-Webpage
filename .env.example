# Application / Clerk
NEXT_PUBLIC_APP_URL=https://www.example.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_ADMIN_ORGANIZATION_ID=

# PostgreSQL / Prisma
# Runtime URL should use the provider's pooled, least-privilege connection.
DATABASE_URL=
# Direct, DDL-capable URL used only by `npm run db:migrate:deploy`.
DIRECT_URL=
# Optional preferred alias for the protected migration job; takes precedence over DIRECT_URL.
MIGRATION_DATABASE_URL=
PG_POOL_MAX=1
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=10000

# Stripe / PayPal
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_PRICE_ID_RAIDMAP_MONTHLY=
STRIPE_PRICE_ID_RAIDMAP_ANNUAL=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_API_BASE=https://api-m.paypal.com

# Bunny Stream (all keys are server-only unless explicitly NEXT_PUBLIC)
BUNNY_LIBRARY_ID=
BUNNY_API_KEY=
# Bunny v1 signs webhooks with the library Read-Only API key. Keep it server-only.
BUNNY_WEBHOOK_SIGNING_SECRET=
BUNNY_EMBED_TOKEN_KEY=
BUNNY_PLAYBACK_TOKEN_TTL_SECONDS=300
NEXT_PUBLIC_BUNNY_LIBRARY_ID=

# Vercel Blob
# Public image store used by the existing image-upload routes.
BLOB_READ_WRITE_TOKEN=
# Separate token belonging to a store configured as PRIVATE. Required for paid PDFs.
BLOB_PRIVATE_READ_WRITE_TOKEN=

# Agent / cron authentication (use independent random values, minimum 32 characters)
AGENT_UPLOAD_TOKEN=
CRON_SECRET=
PAT_UPLOAD_TOKEN=
PAT_UPLOAD_BASE_URL=

# Discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ROLE_MENTEE26_ID=
DISCORD_ANNOUNCEMENTS_CHANNEL_ID=
DISCORD_MOD_CHANNEL_ID=

# Other server-only integrations
BREVO_API_KEY=
BREVO_LIST_ID=
GITHUB_BLOG_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WHOP_API_KEY=
WHOP_PRODUCT_ID=
WHOP_OFFER_ID=
WHOP_STORE_ID=
TRADINGVIEW_COOKIE_ENCRYPTION_KEY=
# One-time only while migrating an existing plaintext AdminSetting; disable again immediately.
ALLOW_LEGACY_TRADINGVIEW_COOKIE_MIGRATION=false
TRADINGVIEW_USER_AGENT=
ANTHROPIC_API_KEY=

# Product configuration / public analytics identifiers
MENTORSHIP_START_DATE=
# Optional comma-separated, verified Clerk primary emails. Empty means no overrides.
MENTORSHIP_ACCESS_OVERRIDE_EMAILS=
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=
NEXT_PUBLIC_GOOGLE_ADS_LEAD_CONVERSION_LABEL=

# Never define NEXT_PUBLIC_BUNNY_API_KEY. If it ever existed, rotate it at Bunny.
